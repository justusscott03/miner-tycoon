{
  "compilerOptions": {
    "target": "ES6",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "allowJs": false,
    "noEmit": false,        // ⭐ IMPORTANT: Webpack needs JS output
    "lib": ["es2017", "dom"],
    "resolveJsonModule": true
  },
  "include": ["src/**/*"]
}
